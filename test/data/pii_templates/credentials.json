      "EMP-{numbers}",
      "ID-{numbers}",
      "USR-{numbers}",
      "ACCT-{numbers}",
      "STAFF-{numbers}"
    ],
    "ssn_format": "{3_digits}-{2_digits}-{4_digits}",
    "passport_format": "{letter}{8_digits}",
    "examples": {
      "usernames": ["jsmith", "john.doe", "john_doe", "john123", "jsmith456", "user789"],
